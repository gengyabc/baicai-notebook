{
  "dbPath": ".opencode/frontmatter-index.sqlite",
  "excludeDirs": [
    ".obsidian",
    ".git",
    "node_modules",
    ".opencode/node_modules",
    ".trash",
    ".opencode/plugins/auto-frontmatter",
    "attachments",
    "raw"
  ],
  "excludePatterns": [
    "\\.tmp$",
    "\\.bak$",
    "\\.DS_Store$",
    "\\.gitkeep$"
  ],
  "debounceMs": 300,
  "_note": "roots and folderPriorities are computed from ../vault-config.json"
}
